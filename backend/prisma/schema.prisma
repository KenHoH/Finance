generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider  = "postgresql"
}

// Transaction type stays as main source of truth
enum TransactionType {
  INCOME
  EXPENSE
}

// Category type adds INVESTMENT as label for category classification
enum CategoryType {
  INCOME
  EXPENSE
  INVESTMENT
}

enum GoalStatus {
  IN_PROGRESS
  ACHIEVED
  CANCELLED
}

enum SplitStatus {
  PENDING
  PARTIALLY_PAID
  SETTLED
}

enum NotificationType {
  BILL_REMINDER
  BUDGET_ALERT
  GOAL_UPDATE
  SYSTEM
}

enum FriendRequestStatus {
  PENDING
  ACCEPTED
  REJECTED
  BLOCKED
}

enum BillStatus {
  PENDING
  PAID
  OVERDUE
}

model Settings {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  key       String
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, key])
  @@index([userId])
}

model User {
  id            String             @id @default(uuid())
  username      String
  email         String             @unique
  password      String?            // nullable kalo OAuth users
  avatar        String?
  lastEmailSync DateTime?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  lastHistoryId String?

  identities    AuthIdentities[]
  transactions  Transaction[]
  categories    Category[]
  budgets       Budget[]
  goals         Goal[]
  bills         Bill[]
  settings      Settings[]
  createdBills  SplitBill[]        @relation("CreatedBills")
  billShares    SplitParticipant[]
  notifications Notification[]
  investments   Investment[]
  investmentAllocations InvestmentAllocation[]
  activityLogs  ActivityLog[]

  // Friend relations
  sentFriendRequests     FriendRequest[] @relation("SentFriendRequests")
  receivedFriendRequests FriendRequest[] @relation("ReceivedFriendRequests")
  friendsAsUser1         Friend[]        @relation("User1Friends")
  friendsAsUser2         Friend[]        @relation("User2Friends")
}

model AuthIdentities {
  id            String    @id @default(uuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider      String    // for ex: google
  providerId    String
  providerEmail String    // store exact email dari provider

  accessToken   String?   @db.Text
  refreshToken  String?   @db.Text
  // tokenExpiry removed, system try-catch error instead

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@unique([provider, providerId])
  @@unique([userId, provider]) // 1 account max per user
  @@index([userId])
  @@index([providerEmail])
}

// category customized by user
model Category {
  id           String       @id @default(uuid())
  userId       String?
  user         User?        @relation(fields: [userId], references: [id], onDelete: Cascade)
  name         String
  type         CategoryType // INCOME, EXPENSE, INVESTMENT label
  icon         String?
  bills        Bill[]
  transactions Transaction[]
  budgets      Budget[]
  investments  Investment[]
  investmentAllocations InvestmentAllocation[]
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@unique([userId, name, type])
  @@index([userId])
  @@index([type])
}

// auto/manual tracking
model Transaction {
  id            String          @id @default(uuid())
  userId        String
  user          User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  categoryId    String?
  category      Category?       @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  amount        Decimal         @db.Decimal(12, 2)
  type          TransactionType
  description   String?
  date          DateTime
  isAutoTracked Boolean         @default(false)
  source        String?         // 'GMAIL_PARSER', 'MANUAL', 'BANK_API'
  sourceId      String?         // email messageId, receipt hash, etc. for deduplication
  goalId        String?         // edge case: user langsung beli barang goal
  goal          Goal?           @relation(fields: [goalId], references: [id], onDelete: SetNull)
  billId        String?
  bill          Bill?           @relation(fields: [billId], references: [id], onDelete: SetNull)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@index([userId])
  @@index([categoryId])
  @@index([goalId])
  @@index([billId])
  @@index([date])
  @@index([userId, date])
}

// budget planning - user set by time or by category or both
model Budget {
  id          String    @id @default(uuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  categoryId  String?
  category    Category? @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  amount      Decimal   @db.Decimal(12, 2)
  startDate   DateTime
  endDate     DateTime
  savingPoint SavingPoint?
  debtPoint   DebtPoint?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([userId])
  @@index([categoryId])
  @@index([userId, startDate, endDate])
}

// target finansial
model Goal {
  id            String     @id @default(uuid())
  userId        String
  user          User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  name          String
  targetAmount  Decimal    @db.Decimal(12, 2)
  currentAmount Decimal    @default(0) @db.Decimal(12, 2)
  deadline      DateTime?
  status        GoalStatus @default(IN_PROGRESS)
  transactions  Transaction[] // edge case: langsung beli barang goal
  contributions GoalContribution[]
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  @@index([userId])
  @@index([status])
}

// split bill
model SplitBill {
  id            String            @id @default(uuid())
  creatorId     String
  creator       User              @relation("CreatedBills", fields: [creatorId], references: [id], onDelete: Cascade)
  totalAmount   Decimal           @db.Decimal(12, 2)
  description   String
  date          DateTime
  status        SplitStatus       @default(PENDING)
  receiptProofs String[]          @default([])
  participants  SplitParticipant[]
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  @@index([creatorId])
  @@index([date])
  @@index([status])
}

// orang yg terlibat di splitbill
model SplitParticipant {
  id           String    @id @default(uuid())
  splitBillId  String
  splitBill    SplitBill @relation(fields: [splitBillId], references: [id], onDelete: Cascade)
  userId       String?
  user         User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  name         String?   // fallback kalau temannya itu ga ada di akun
  amountOwed   Decimal   @db.Decimal(12, 2)
  isPaid       Boolean   @default(false)
  paidAt       DateTime?
  paymentProof String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([splitBillId])
  @@index([userId])
}

model Notification {
  id        String           @id @default(uuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType // distinguish notification template message
  title     String
  message   String
  isRead    Boolean          @default(false)
  readAt    DateTime?
  createdAt DateTime         @default(now())

  @@index([userId])
  @@index([userId, readAt])
  @@index([type])
  @@index([createdAt])
}

// Friend requests between users
model FriendRequest {
  id         String              @id @default(uuid())
  senderId   String
  sender     User                @relation("SentFriendRequests", fields: [senderId], references: [id], onDelete: Cascade)
  receiverId String
  receiver   User                @relation("ReceivedFriendRequests", fields: [receiverId], references: [id], onDelete: Cascade)
  status     FriendRequestStatus @default(PENDING)
  createdAt  DateTime            @default(now())
  updatedAt  DateTime            @updatedAt

  @@unique([senderId, receiverId])
  @@index([senderId])
  @@index([receiverId])
  @@index([status])
}

// Established friendships (bidirectional)
model Friend {
  id        String   @id @default(uuid())
  user1Id   String
  user1     User     @relation("User1Friends", fields: [user1Id], references: [id], onDelete: Cascade)
  user2Id   String
  user2     User     @relation("User2Friends", fields: [user2Id], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([user1Id, user2Id])
  @@index([user1Id])
  @@index([user2Id])
}

// ============================================================
// NEW TABLES
// ============================================================

// history kontribusi ke goal, bisa pakai saving point sebagai source
model GoalContribution {
  id               String       @id @default(uuid())
  goalId           String
  goal             Goal         @relation(fields: [goalId], references: [id], onDelete: Cascade)
  savingPointId    String?      // optional: kalau pakai saving point
  savingPoint      SavingPoint? @relation(fields: [savingPointId], references: [id], onDelete: SetNull)
  amount           Decimal      @db.Decimal(12, 2)
  contributionDate DateTime
  note             String?
  createdAt        DateTime     @default(now())

  @@index([goalId])
  @@index([savingPointId])
  @@index([contributionDate])
  @@index([goalId, contributionDate])
}

model Bill {
  id                String      @id @default(uuid())
  userId            String
  user              User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  categoryId        String?
  category          Category?   @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  title             String
  amount            Decimal     @db.Decimal(12, 2)
  dueDate           DateTime
  status            BillStatus  @default(PENDING)
  isReminderEnabled Boolean     @default(true)
  remindAt          DateTime?
  paidAt            DateTime?
  transactions      Transaction[]
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  @@index([userId])
  @@index([categoryId])
  @@index([dueDate])
  @@index([status])
  @@index([userId, dueDate])
  @@index([isReminderEnabled, dueDate])
}

// total sisa uang (underbudget) per budget, bisa dipakai untuk goals
model SavingPoint {
  id           String             @id @default(uuid())
  budgetId     String             @unique
  budget       Budget             @relation(fields: [budgetId], references: [id], onDelete: Cascade)
  savingAmount Decimal            @db.Decimal(12, 2)
  contributions GoalContribution[] // track penggunaan untuk goals
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
}

// total amount per investment module (saham, emas, reksadana)
model Investment {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  categoryId  String
  category    Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  totalAmount Decimal  @db.Decimal(12, 2)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([userId, categoryId]) // 1 row per user per investment category
  @@index([userId])
  @@index([categoryId])
}

// detail saving yang dialokasikan ke investment
model InvestmentAllocation {
  id             String    @id @default(uuid())
  userId         String
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  categoryId     String
  category       Category  @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  amount         Decimal   @db.Decimal(12, 2)
  allocationDate DateTime
  note           String?
  createdAt      DateTime  @default(now())

  @@index([userId])
  @@index([categoryId])
  @@index([allocationDate])
  @@index([userId, categoryId])
}

// total overbudget per budget
model DebtPoint {
  id         String   @id @default(uuid())
  budgetId   String   @unique
  budget     Budget   @relation(fields: [budgetId], references: [id], onDelete: Cascade)
  debtAmount Decimal  @db.Decimal(12, 2)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// optional logging table
model ActivityLog {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  action    String   // CREATE, UPDATE, DELETE, LOGIN, etc
  entity    String   // Transaction, Budget, Goal, etc
  entityId  String?
  details   String?  @db.Text
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([entity])
  @@index([createdAt])
}

