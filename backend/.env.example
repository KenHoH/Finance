
# Server
PORT=3000
NODE_ENV=development
JWT_SECRET=replace-with-a-long-random-secret
FRONTEND_URL=http://localhost:5173
ALLOWED_ORIGINS=http://localhost:5173
COOKIE_DOMAIN=
COOKIE_SAMESITE=lax

# Database Connection
DATABASE_URL=postgresql://user:password@host:5432/database?pgbouncer=true
DIRECT_URL=postgresql://user:password@host:5432/database

# Google OAuth Credentials
CLIENT_ID=replace-with-google-oauth-client-id
CLIENT_SECRET=replace-with-google-oauth-client-secret

# Gmail API Key
API_KEY=replace-with-google-api-key

# Google OAuth Redirect URI
REDIRECT_URI=http://localhost:3000/auth/google/callback

# External Services
OCR_SERVICE_URL=http://localhost:5000
GMAIL_WATCH_TOPIC=projects/your-project/topics/your-topic

# Redis / Queue
REDIS_URL=redis://localhost:6379
REDIS_HOST=
REDIS_PORT=
REDIS_PASSWORD=
REDIS_TLS=false

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=replace-with-supabase-service-key
